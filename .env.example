# ============================================
# ATLAS LEATHER — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- PayPal ---
NEXT_PUBLIC_PAYPAL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
PAYPAL_ENV=sandbox

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://atlasleather.ma
NEXT_PUBLIC_SITE_NAME="Atlas Leather"

# --- Email (notifications de commande - Resend recommandé) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
NOTIFICATION_EMAIL=contact@atlasleather.ma

# --- Contact ---
NEXT_PUBLIC_WHATSAPP_NUMBER=212600000000
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/atlasleather.ma
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/atlasleather.ma
